# .env.example for Copytree
# -----------------------------------------
# Copy this file to ~/.copytree/.env and update the values below.
#
# Gemini API Credentials (required for AI‑based features)
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Request Timeout (in seconds)
GEMINI_REQUEST_TIMEOUT=60

# Gemini Model to use (default is "models/gemini-2.0-flash")
GEMINI_MODEL=models/gemini-2.0-flash

# Application Environment Settings
APP_NAME=copytree
APP_ENV=production
APP_DEBUG=false
