# .env.example for Copytree
# -----------------------------------------
# Copy this file to ~/.copytree/.env and update the values below.
#
# Application Settings
APP_NAME=Copytree
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=UTC

# Logging Configuration
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_RETENTION_DAYS=14
LOG_SLACK_WEBHOOK_URL=
LOG_SLACK_LEVEL=critical
LOG_DEPRECATIONS_CHANNEL=deprecations
LOG_DEPRECATIONS_TRACE=false

# Database Configuration
DB_CONNECTION=sqlite
DB_DATABASE=storage/database.sqlite

# AI Provider Settings
AI_DEFAULT_PROVIDER=fireworks

# Fireworks API Configuration
FIREWORKS_API_KEY=
FIREWORKS_API_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_REQUEST_TIMEOUT=120

# OpenAI API Configuration
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_REQUEST_TIMEOUT=120

# AI Model Configuration
AI_DEFAULT_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic
AI_ASK_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic
AI_EXPERT_SELECTOR_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic
AI_SUMMARIZATION_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic
AI_CLASSIFICATION_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic
AI_GENERAL_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic
AI_FILTER_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic
AI_FILENAME_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic

# AI Parameter Configuration
AI_DEFAULT_TEMPERATURE=0.7
AI_DEFAULT_MAX_TOKENS=2048
AI_DEFAULT_TOP_P=0.9
AI_DEFAULT_STREAM=true

# Task-Specific AI Parameters
AI_SUMMARIZATION_TEMPERATURE=0.3
AI_SUMMARIZATION_MAX_TOKENS=1024
AI_CLASSIFICATION_TEMPERATURE=0.2
AI_CLASSIFICATION_MAX_TOKENS=256
AI_EXPERT_SELECTION_TEMPERATURE=0.2
AI_EXPERT_SELECTION_MAX_TOKENS=256
AI_FILENAME_TEMPERATURE=0.5
AI_FILENAME_MAX_TOKENS=128

# AI Caching Configuration
AI_CACHE_ENABLED=true
AI_CACHE_TTL=1440
AI_CACHE_PREFIX=ai_response:

# AI Rate Limiting Configuration
AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_PERIOD=60

# State Configuration
STATE_GARBAGE_COLLECTION_DEFAULT_DAYS=7
