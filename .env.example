# .env.example for Copytree
# -----------------------------------------
# Copy this file to ~/.copytree/.env and update the values below.
#
# Fireworks API Credentials (required for AI‑based features)
FIREWORKS_API_KEY=your-fireworks-api-key-here

# Fireworks Request Timeout (in seconds)
FIREWORKS_REQUEST_TIMEOUT=60

# Fireworks Models
FIREWORKS_ASK_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic
FIREWORKS_EXPERT_SELECTOR_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic
FIREWORKS_SUMMARIZATION_MODEL=accounts/fireworks/models/llama3-8b-instruct
FIREWORKS_CLASSIFICATION_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic
FIREWORKS_GENERAL_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic

# Application Environment Settings
APP_NAME=copytree
APP_ENV=production
APP_DEBUG=false
