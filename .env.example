# .env.example for Copytree
# -----------------------------------------
# Copy this file to ~/.copytree/.env and update the values below.
#
# OpenAI API Credentials (required for AI‑based filtering,
# summarization, and filename generation features)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_ORGANIZATION=your-openai-organization-id-here

# OpenAI Request Timeout (in seconds)
OPENAI_REQUEST_TIMEOUT=60

# OpenAI Model to use (default is "gpt-4o")
OPENAI_MODEL=gpt-4o

# Application Environment Settings
APP_NAME=copytree
APP_ENV=production
APP_DEBUG=false
